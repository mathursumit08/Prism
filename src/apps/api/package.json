{
  "name": "api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "20.19.6"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "preworker:forecast": "npm run migrate",
    "worker:forecast": "node src/workers/forecastWorker.js",
    "preforecast:run": "npm run migrate",
